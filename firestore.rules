rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomId} {
      // 認証済みユーザーは招待コードで部屋を検索・参照できる
      allow read: if request.auth != null;

      // 認証済みユーザーは自分がオーナーとして部屋を作成できる
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;

      // オーナーは部屋を更新・削除できる
      allow update, delete: if request.auth != null
                             && request.auth.uid == resource.data.ownerId;

      // メンバーは招待コードで参加（自分を memberUids に追加）できる
      allow update: if request.auth != null
                    && request.auth.uid in request.resource.data.memberUids
                    && !request.resource.data.keys().hasAny(['ownerId'])
                       == false  // ownerId フィールドは必ず存在する
                    && request.resource.data.ownerId == resource.data.ownerId;

      // メンバーは自分自身を退出（memberUids から自分の UID を削除）できる
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.memberUids
                    && request.auth.uid != resource.data.ownerId
                    && request.resource.data.ownerId == resource.data.ownerId
                    && !request.resource.data.memberUids.hasAny([request.auth.uid]);

      // 大会データ: 部屋のメンバーのみ読み書きできる
      match /tournaments/{tournamentId} {
        allow read, write: if request.auth != null
                           && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.memberUids;
      }
    }
  }
}
